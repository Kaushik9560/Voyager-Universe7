flowchart TB
    U["1. User Layer<br/>Query + Filters Input"]
    C["2. Control Layer<br/>Query Parsing + Flow Control"]
    D["3. Data Layer<br/>Travel Data from Multiple Sources (Parallel)"]
    L["4. Logic Layer<br/>Filtering + Scoring + Ranking"]
    A["5. AI Layer<br/>Chat Support + Itinerary Generation"]
    O["6. Output Layer<br/>Final Dashboard + Day-wise Travel Plan"]

    U --> C --> D --> L --> A --> O
    C -->|Context| A

    TBO[("TBO Travel APIs")]
    GP[("Google Places")]
    WX[("Weather / Forecast API")]

    TBO --> D
    GP --> D
    WX --> D

    F["Reliability: Graceful Fallback"]
    D --> F
    A --> F
    F --> O

    classDef layer fill:#eaf4ff,stroke:#3b82f6,stroke-width:1.5px,color:#0f172a;
    classDef source fill:#ecfeff,stroke:#14b8a6,stroke-width:1.2px,color:#0f172a;
    classDef reliability fill:#fff7ed,stroke:#f97316,stroke-width:1.5px,color:#7c2d12;

    class U,C,D,L,A,O layer;
    class TBO,GP,WX source;
    class F reliability;
