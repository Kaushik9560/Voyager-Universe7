# =========================
# Voyager Environment Template
# =========================

# Use mock/fallback inventory for local demos.
# Set to false only when all live vendor credentials are configured.
USE_MOCK_DATA=true

# -------------------------
# Auth and AI
# -------------------------
AUTH_SECRET=replace-with-a-long-random-secret
AI_API_KEY=
AI_MODEL=
# Optional legacy compatibility keys
GEMINI_API_KEY=
GEMINI_MODEL=

# -------------------------
# Google Places
# -------------------------
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_TIMEOUT_MS=8000

# -------------------------
# TBO Hotel
# -------------------------
TBO_USERNAME=your_tbo_hotel_username
TBO_PASSWORD=your_tbo_hotel_password
TBO_HOTEL_API_URL=http://api.tbotechnology.in/HotelAPI_V7/HotelService.svc

# Optional compatibility keys used by some branches
TBO_HOTEL_USERNAME=
TBO_HOTEL_PASSWORD=
TBO_HOTEL_BASE_URL=http://api.tbotechnology.in/TBOHolidays_HotelAPI
TBO_HOTEL_COUNTRY_CODE=IN
TBO_HOTEL_CATALOG_ONLY=true
TBO_HOTEL_CATALOG_RESULT_LIMIT=300
TBO_HOTEL_CODE_LIMIT=240
TBO_HOTEL_FLEX_SEARCH=true
TBO_HOTEL_FLEX_DAY_OFFSETS=0,2,7
TBO_HOTEL_SEARCH_TIMEOUT_MS=12000
# Optional JSON map for forcing demo hotel codes by city
# TBO_DEMO_HOTEL_CODES={"goa":["1247101"]}

# -------------------------
# TBO Air
# -------------------------
TBO_AIR_BASE=https://api.tektravels.com
TBO_SHARED_BASE=http://Sharedapi.tektravels.com
TBO_END_USER_IP=127.0.0.1
TBO_AIR_USERNAME=your_tbo_air_username
TBO_AIR_PASSWORD=your_tbo_air_password
TBO_AIR_AUTH_URL=https://api.tektravels.com/Authenticate/ValidateAgency
TBO_AIR_SEARCH_URL=https://api.tektravels.com/BookingEngineService_Air/AirService.svc/rest/Search
TBO_AIR_FAREQUOTE_URL=https://api.tektravels.com/BookingEngineService_Air/AirService.svc/rest/FareQuote
TBO_AIR_FARERULE_URL=https://api.tektravels.com/BookingEngineService_Air/AirService.svc/rest/FareRule
TBO_AIR_SSR_URL=https://api.tektravels.com/BookingEngineService_Air/AirService.svc/rest/SSR
TBO_AIR_URL=https://api.tektravels.com

# -------------------------
# TBO B2B Login (optional)
# -------------------------
TBO_B2B_URL=https://api.tektravels.com
TBO_B2B_USERNAME=
TBO_B2B_PASSWORD=
